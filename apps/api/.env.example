STATMENTOR_ENVIRONMENT=local
STATMENTOR_DEBUG=true
STATMENTOR_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/statmentor
STATMENTOR_DATABASE_ECHO=false
STATMENTOR_DATABASE_POOL_SIZE=5
STATMENTOR_DATABASE_MAX_OVERFLOW=10
STATMENTOR_DATABASE_POOL_TIMEOUT_SECONDS=30
STATMENTOR_CORS_ORIGINS=["http://localhost:3000"]
STATMENTOR_DEVELOPMENT_USER_ID=00000000-0000-4000-8000-000000000001
STATMENTOR_DEVELOPMENT_USER_EMAIL=developer@statmentor.local
STATMENTOR_DEVELOPMENT_USER_NAME=StatMentor Developer
STATMENTOR_DEVELOPMENT_PROJECT_ID=00000000-0000-4000-8000-000000000002
STATMENTOR_DEVELOPMENT_PROJECT_TITLE=Sample Dissertation Project
STATMENTOR_UPLOAD_ROOT=./storage/uploads
STATMENTOR_MAX_UPLOAD_SIZE_BYTES=26214400
STATMENTOR_DATASET_PREVIEW_MAX_ROWS=100
